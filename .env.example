# Argus configuration — `cp .env.example .env`. NEVER commit .env.
# Everything here is optional; the defaults are fully local and free.

# ===========================================================================
# MODELS — pick ONE block. LOCAL (Ollama) is the default ($0, no API key).
# To use a hosted model, comment LOCAL and uncomment a key + the FRONTIER models.
# ===========================================================================

# --- LOCAL (Ollama) — zero cost. Default. ---
# Needs: `ollama serve` + `ollama pull qwen2.5:3b` + `ollama pull nomic-embed-text`.
ARGUS_MODEL=ollama_chat/qwen2.5:3b
ARGUS_EMBEDDING_MODEL=ollama/nomic-embed-text

# --- FRONTIER (hosted) — paid; needed to pass the eval gate. ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# ARGUS_MODEL=openai/gpt-5.4-mini
# ARGUS_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Infra ---
ARGUS_SEARXNG_HOST=localhost
ARGUS_SEARXNG_PORT=8080          # `make up` writes the chosen free port here
ARGUS_REQUEST_TIMEOUT_S=30.0

# Agent budget — the 3-axis budget + cost cap that stops runaway research.
ARGUS_MAX_TURNS=8
ARGUS_MAX_TOKENS=120000
ARGUS_MAX_WALLCLOCK_S=180.0
ARGUS_MAX_COST_USD=0.50

# --- Optional capabilities (off by default) ---
# Distributed searchers on ARQ-on-Redis (KEDA-autoscalable):
# ARGUS_USE_QUEUE=true
# ARGUS_REDIS_URL=redis://localhost:6379/0
# Crash-resumable deep research via DBOS (needs `uv sync --extra durable`):
# ARGUS_USE_DURABLE=true
# Cross-encoder rerank stage (needs `uv sync --extra rerank`):
# ARGUS_RERANK_ENABLED=true
# OpenTelemetry tracing (needs `uv sync --extra otel` + a collector on :4318):
# ARGUS_OTEL_ENABLED=true
# Auth secrets (>=32 bytes) — REQUIRED outside development:
# ARGUS_ENVIRONMENT=production
# ARGUS_JWT_SECRET=change-me-to-a-unique-32-byte-secret
# ARGUS_CSRF_SECRET=change-me-to-another-unique-32-byte-secret

# --- Logging ---
ARGUS_LOG_LEVEL=INFO
ARGUS_LOG_JSON=false
