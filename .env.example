# Argus configuration — copy to .env and fill in. NEVER commit .env.
#
# LiteLLM reads provider API keys directly from the environment by their
# conventional names (NOT the ARGUS_ prefix). Set whichever provider you use:
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# Argus-specific settings (Pydantic Settings, ARGUS_ prefix) — all optional;
# the defaults below are what the app uses if unset.
ARGUS_MODEL=anthropic/claude-sonnet-4-6
ARGUS_REQUEST_TIMEOUT_S=30.0

# SearXNG location. `make up` picks the first free port from 8080 and writes
# ARGUS_SEARXNG_PORT here so the app and the container agree on one port.
ARGUS_SEARXNG_HOST=localhost
ARGUS_SEARXNG_PORT=8080

# Agent budget — the 3-axis budget + cost cap that stops runaway research.
ARGUS_MAX_TURNS=8
ARGUS_MAX_TOKENS=120000
ARGUS_MAX_WALLCLOCK_S=180.0
ARGUS_MAX_COST_USD=0.50

# Distributed scale — fan searchers out onto ARQ-on-Redis (KEDA-autoscalable).
# ARGUS_USE_QUEUE=false
# ARGUS_REDIS_URL=redis://localhost:6379/0

# API rate limiting (Redis sliding window; needs ARGUS_REDIS_URL).
# ARGUS_RATE_LIMIT_ENABLED=false
# ARGUS_RATE_LIMIT_REQUESTS=60
# ARGUS_RATE_LIMIT_WINDOW_S=60.0

# OpenTelemetry tracing — needs the `otel` extra (uv sync --extra otel) + a
# collector. `docker compose --profile otel up jaeger` serves the UI on :16686.
# ARGUS_OTEL_ENABLED=false
# ARGUS_OTEL_ENDPOINT=http://localhost:4318

# Langfuse LLM tracing (LLMOps). Run Langfuse self-hosted (its own docker-compose,
# https://langfuse.com/self-hosting) or Langfuse Cloud, then set these:
# ARGUS_LANGFUSE_ENABLED=false
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000

# Logging
ARGUS_LOG_LEVEL=INFO
ARGUS_LOG_JSON=false
